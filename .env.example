# App
ENVIRONMENT=dev
PORT=8000
APP_NAME=UniversalRAG
LOG_LEVEL=INFO

# MongoDB
DATABASE_URI=mongodb://localhost:27017
DATABASE_NAME=universal_rag_db
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=5

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENABLED=false

# Compression
ENABLE_COMPRESSION=true
COMPRESSION_MIN_SIZE_BYTES=102400
COMPRESSION_LEVEL=6

# Migrations
AUTO_MIGRATE=true

# Request logging
ENABLE_REQUEST_BODY_LOGGING=false
